#the mod name as displayed in-game
displayName: "Oxygen Core"

#the internal name of your mod
name: "oxygen-core"

#your name
author: "emmmm9o"

#the fully qualified main class of the mod
main: "com.github.emmmm9o.oxygencore.core.CoreMod"

#the mod description as seen in the mod dialog
description: "a library mod"

#the mod version
version: 1.0

#the minimum game build required to run this mod
minGameVersion: 145

#this is a java mod
java: true
